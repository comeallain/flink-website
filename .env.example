# Public site URL (required; validated at startup)
PUBLIC_SITE_URL=http://localhost:5173

# Supabase (optional; required for waitlist signup form)
# Get these from your Supabase project: Dashboard → Settings → API
PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only: required for live signup count (Final CTA / Hero). Do not expose.
# Use the SECRET key from Dashboard → API → Secret keys (not the Publishable key).
# The Publishable key obeys RLS and cannot read waitlist_signups, so the count would stay 0.
SUPABASE_SERVICE_ROLE_KEY=your-secret-key

# Analytics (optional — omit or leave blank to disable each provider)
PUBLIC_META_PIXEL_ID=your-pixel-id